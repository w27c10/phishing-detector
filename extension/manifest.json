{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0.0",
  "description": "Real-time explainable AI phishing detection powered by a multi-branch deep learning model.",
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "http://localhost:5000/*",
    "https://*.up.railway.app/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ]
}
